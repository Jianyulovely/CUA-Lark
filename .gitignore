# ── 敏感配置（绝对不能提交）──────────────────────────────────────
.env

# ── Python 编译缓存 ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.pyo

# ── 测试脚本目录（本地运行，不上传）─────────────────────────────
tests/

# ── 设计文档 Word 版本 ────────────────────────────────────────────
*.docx

# ── 测试 / 构建产物 ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# ── 运行时产物（截图、日志）──────────────────────────────────────
screenshots/
*.log

# ── 参考代码仓库（只读参考，不纳入本项目版本管理）──────────────
computer_use_ootb/

# ── IDE / 编辑器 / 工具 ───────────────────────────────────────────
.vscode/
.idea/
*.swp
.claude/
